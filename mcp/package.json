{
  "name": "taiwan-workday-mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Remote MCP server exposing Taiwan workday/time calculations (台灣工作日計算引擎)",
  "type": "module",
  "scripts": {
    "gen": "node scripts/gen-manifest.mjs",
    "predev": "npm run gen",
    "prebuild": "npm run gen",
    "pretest": "npm run gen",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "npm run gen && tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "agents": "^0.0.80",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
